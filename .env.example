# Last.fm
LASTFM_API_KEY=
LASTFM_SHARED_SECRET=
LASTFM_SESSION_KEY=
LASTFM_USERNAME=

# ListenBrainz
LISTENBRAINZ_TOKEN=
LISTENBRAINZ_USERNAME=

# Discogs
DISCOGS_TOKEN=

# Tracker selection
TRACKER_MODE=both
PRIMARY_TRACKER=red

# RED (Redacted)
RED_API_KEY=
RED_USE_FREELEECH_TOKEN=never
RED_QUALITY_PROFILE=flac_any
RED_MEDIA_PREFERENCE=cd
RED_MEDIA_SCORE_CD=100
RED_MEDIA_SCORE_WEB=50
RED_MEDIA_SCORE_VINYL=-10000
RED_MEDIA_SCORE_CASSETTE=0
RED_MEDIA_SCORE_SACD=90
RED_MEDIA_SCORE_BLU_RAY=80
RED_MEDIA_SCORE_DVD=70
RED_MEDIA_SCORE_SOUNDBOARD=20

# OPS (Orpheus)
OPS_API_KEY=
OPS_USE_FREELEECH_TOKEN=never

# qBittorrent
QBT_HOST=http://localhost:8080
QBT_USERNAME=admin
QBT_PASSWORD=adminadmin
QBT_CATEGORY=music
QBT_RED_TAG=RED
QBT_OPS_TAG=OPS
# Enables guarded RED-to-OPS and OPS-to-RED cross-seed matching.
OPS_CROSS_SEED=0

# Navidrome
NAVIDROME_URL=http://localhost:4533
NAVIDROME_USER=
NAVIDROME_PASS=

# Auth
APP_THEME=redwave
APP_USERNAME=admin
APP_PASSWORD=redwave
SECRET_KEY=change-me-to-a-random-secret

# Database
DATABASE_URL=sqlite+aiosqlite:///./redwave.db

# Music directory (for local scanner fallback)
MUSIC_DIR=/music
